# MiCASA_v1 pipeline — track scripts + docs only, not data products
# ----------------------------------------------------------------

# Data products (regenerated from upstream + processing scripts)
*.nc
*.nc4

# Large R workspaces (e.g. fit.piqs.rda — 226 MB) plus the per-fitter
# bake-off variants (fit.piqs.rda.pchip, .mss, .before-atmc, …)
*.rda
fit.piqs.rda.*

# SLURM job logs — both in jobs/ and anywhere they land in root
jobs/
*.o[0-9]*

# Bulk data / output subdirectories (regenerated, too large for git)
daily_1x1/
monthly_1x1/
ERA5/
portal.nccs.nasa.gov
figures/

# HTTP mirror cruft from upstream NCCS portal listings
index.html*

# Editor / OS / scratch
.DS_Store
.~
*~
.*.swp

# Local convenience — uncomment if needed
# *.local
# scratch/

# Diagnostic outputs (regenerated by helper scripts)
diag_v1_vNRT_handoff.csv
diag_v1_vNRT_handoff.pdf
verify_v2_summary.csv
# verify_*.r helper JSON outputs (verify_pchip_invariants.json, etc.)
verify_*.json
*.rda.prev
__pycache__/

# Bake-off / smoke logs (regenerated)
*.log

# committed documentation figures (override the *.png ignore)
!docs/figures/
!docs/figures/*.png
